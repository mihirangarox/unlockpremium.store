rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow access to social proof collections
    match /posts/{doc} { allow read, write: if true; }
    match /testimonials/{doc} { allow read, write: if true; }

    // CRM & eCommerce Collections (Temporary open access for development)
    match /products/{doc} { allow read, write: if true; }
    match /customers/{doc} { allow read, write: if true; }
    match /subscriptions/{doc} { allow read, write: if true; }
    match /requests/{doc} { allow read, write: if true; }
    match /reminders/{doc} { allow read, write: if true; }
    match /renewal_history/{doc} { allow read, write: if true; }
    match /activity_logs/{doc} { allow read, write: if true; }
    match /vendors/{doc} { allow read, write: if true; }
    match /inventory/{doc} { allow read, write: if true; }
    match /inventory_logs/{doc} { allow read, write: if true; }
    match /usdt_transactions/{doc} { allow read, write: if true; }
    match /live_stock/{doc} { allow read, write: if true; }
    
    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

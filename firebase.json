{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/posts",
        "function": "api"
      },
      {
        "source": "/posts/**",
        "function": "api"
      },
      {
        "source": "/testimonials",
        "function": "api"
      },
      {
        "source": "/testimonials/**",
        "function": "api"
      },
      {
        "source": "/upload-image",
        "function": "api"
      },
      {
        "source": "/sitemap.xml",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|gif|png|webp|svg|css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}
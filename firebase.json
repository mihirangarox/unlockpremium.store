{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/posts",
        "function": "api"
      },
      {
        "source": "/posts/**",
        "function": "api"
      },
      {
        "source": "/testimonials",
        "function": "api"
      },
      {
        "source": "/testimonials/**",
        "function": "api"
      },
      {
        "source": "/upload-image",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}